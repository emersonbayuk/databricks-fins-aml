# Databricks Configuration
DATABRICKS_TOKEN=your_databricks_token_here
DATABRICKS_WAREHOUSE_ID=your_warehouse_id_here

# Service Principal for Dashboard Embedding (REQUIRED for dark mode)
# The user's OAuth token doesn't have embedding scopes - you need a service principal!
# Steps to configure:
# 1. Create service principal: Settings > Identity & Access > Service Principals > Add
# 2. Generate secret: Click service principal > Secrets > Generate secret
# 3. Grant dashboard access: Dashboard > Share > Add service principal with CAN RUN
# 4. Set the secret below:
SERVICE_PRINCIPAL_ID=d614dc36-61a2-4f78-a817-beaf28597575  # This is app-jqs3an
SERVICE_PRINCIPAL_SECRET=  # ADD YOUR SECRET HERE - REQUIRED FOR DARK MODE!

# Neo4j Aura Configuration
NEO4J_URI=neo4j+s://398dd975.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Neo4j Instance Details (for reference)
# Instance ID: 398dd975
# Query API: https://398dd975.databases.neo4j.io/db/{databaseName}/query/v2
# Version: 2025.11
# Region: AWS US East (us-east-1)
# Type: AuraDB Professional