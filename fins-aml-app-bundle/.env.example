# =============================================================================
# FINS AML Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for your target workspace.
# All values below default to the dev workspace if not set.
# =============================================================================

# --- Databricks Workspace ---
DATABRICKS_HOSTNAME=fe-vm-industry-solutions-buildathon.cloud.databricks.com
DATABRICKS_WORKSPACE_ID=237438879023004
DATABRICKS_WAREHOUSE_ID=your_warehouse_id_here

# --- Service Principal (OAuth M2M) ---
# The Databricks Apps runtime auto-injects DATABRICKS_CLIENT_ID and
# DATABRICKS_CLIENT_SECRET for the app's service principal. For local
# development, set them here manually.
DATABRICKS_CLIENT_ID=your_client_id_here
DATABRICKS_CLIENT_SECRET=your_client_secret_here
# Optional PAT fallback (only needed if SP credentials are unavailable):
# DATABRICKS_TOKEN=your_databricks_token_here

# --- Unity Catalog ---
DATABRICKS_CATALOG=fins_aml
DATABRICKS_SCHEMA=data_generation

# --- Dashboard ---
DATABRICKS_DASHBOARD_ID=01f0ef2a97ed176dbe998b9ec4577b1b

# --- MAS Agent Endpoint ---
MAS_ENDPOINT_URL=https://fe-vm-industry-solutions-buildathon.cloud.databricks.com/serving-endpoints/mas-38750666-endpoint/invocations

# --- Neo4j Aura ---
NEO4J_URI=neo4j+s://398dd975.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# Neo4j Instance Details (for reference)
# Instance ID: 398dd975
# Query API: https://398dd975.databases.neo4j.io/db/{databaseName}/query/v2
# Version: 2025.11
# Region: AWS US East (us-east-1)
# Type: AuraDB Professional
